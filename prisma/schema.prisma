generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  quickReviewQuota Int      @default(3)
  deepReviewQuota  Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
